{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3BucketAccess",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::youtube-data-pipeline-2026-bronze-us-east-1",
                "arn:aws:s3:::youtube-data-pipeline-2026-silver-us-east-1",
                "arn:aws:s3:::youtube-data-pipeline-2026-gold-us-east-1",
                "arn:aws:s3:::youtube-data-pipeline-2026-script-us-east-1"
            ]
        },
        {
            "Sid": "S3ObjectAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::youtube-data-pipeline-2026-bronze-us-east-1/*",
                "arn:aws:s3:::youtube-data-pipeline-2026-silver-us-east-1/*",
                "arn:aws:s3:::youtube-data-pipeline-2026-gold-us-east-1/*",
                "arn:aws:s3:::youtube-data-pipeline-2026-script-us-east-1/*"
            ]
        }
    ]
}